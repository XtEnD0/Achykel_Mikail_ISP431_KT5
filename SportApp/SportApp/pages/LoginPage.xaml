<Page x:Class="SportApp.pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SportApp.pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Страница авторизации">

    <Grid>
        <StackPanel Background="WhiteSmoke"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
            <Label Content="Логин:" HorizontalAlignment="Center"></Label>
            <TextBox x:Name="LoginTextBox"
                     Margin="10,0,10,10"></TextBox>
            <Label Content="Пароль:" HorizontalAlignment="Center"></Label>
            <PasswordBox x:Name="PasswordPasBox" Width="150"
                         Margin="10,0,10,10"></PasswordBox>

            <Button x:Name="LoginButton" Click="LoginButton_Click"
                Content="Войти" Width="150" Margin="0,0,0,10"></Button>
            
            
        </StackPanel>
        
        
    </Grid>
</Page>
